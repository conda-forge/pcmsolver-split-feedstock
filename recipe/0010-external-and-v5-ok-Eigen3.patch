From 76e2c21c4e11f32bcb5812f65fb1eda25b924150 Mon Sep 17 00:00:00 2001
From: "Lori A. Burns" <lori.burns7@gmail.com>
Date: Fri, 27 Mar 2026 13:27:08 -0400
Subject: [PATCH 2/2] external and v5 ok Eigen3

---
 CMakeLists.txt           |  1 +
 cmake/custom/eigen.cmake | 15 +++------------
 2 files changed, 4 insertions(+), 12 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 946101cc..ffecb605 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -7,6 +7,7 @@ cmake_policy(SET CMP0053 NEW)
 if(POLICY CMP0177)
     cmake_policy(SET CMP0177 NEW)
 endif()
+cmake_policy(SET CMP0074 NEW)
 
 # project name
 project(PCMSolver LANGUAGES CXX C Fortran)
diff --git a/cmake/custom/eigen.cmake b/cmake/custom/eigen.cmake
index 7882a8ed..a4a47aee 100644
--- a/cmake/custom/eigen.cmake
+++ b/cmake/custom/eigen.cmake
@@ -10,16 +10,7 @@
 #   docopt: "--eigen=<EIGEN3_ROOT> Root directory for Eigen3 [default: '']."
 #   define: "'-DEIGEN3_ROOT=\"{0}\"'.format(arguments['--eigen'])"
 
-if(EIGEN3_ROOT)
-  set(EIGEN3_INCLUDE_DIR ${EIGEN3_ROOT}/include)
-  find_package(Eigen3 3.3.0)
-  message(STATUS "Eigen FOUND " ${EIGEN3_VERSION_STRING} " is located here: " ${EIGEN3_INCLUDE_DIR})
-  if(NOT EIGEN3_FOUND)
-    set(EIGEN3_INCLUDE_DIR ${PROJECT_SOURCE_DIR}/external/eigen3/include/eigen3)
-    message(STATUS "Eigen 3.3.2 is located here: " ${EIGEN3_INCLUDE_DIR})
-  endif()
-else()
-  set(EIGEN3_INCLUDE_DIR ${PROJECT_SOURCE_DIR}/external/eigen3/include/eigen3)
-  message(STATUS "Eigen 3.3.2 is located here: " ${EIGEN3_INCLUDE_DIR})
-endif()
+find_package(Eigen3 REQUIRED)
+get_target_property(EIGEN3_INCLUDE_DIR Eigen3::Eigen INTERFACE_INCLUDE_DIRECTORIES)
+message(STATUS "Eigen (found=${Eigen3_FOUND}) " ${Eigen3_VERSION} " is located here: " ${EIGEN3_INCLUDE_DIR})
 include_directories(SYSTEM ${EIGEN3_INCLUDE_DIR})
-- 
