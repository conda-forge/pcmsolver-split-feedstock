From c2b304d9e0ece1c92ee12a65954914a60c80a5bc Mon Sep 17 00:00:00 2001
From: Lori Burns <lori.burns@gmail.com>
Date: Fri, 27 Mar 2026 04:11:18 -0400
Subject: [PATCH 1/1] old-eigen-detection

---
 CMakeLists.txt           |  3 ++-
 cmake/custom/eigen.cmake | 13 +------------
 2 files changed, 3 insertions(+), 13 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index a7c5673a..082e01ac 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -2,8 +2,9 @@
 # Copyright (c) 2015-2018 by Radovan Bast, Roberto Di Remigio, Jonas Juselius, and contributors.
 
 # set minimum cmake version
-cmake_minimum_required(VERSION 3.3 FATAL_ERROR)
+cmake_minimum_required(VERSION 3.15 FATAL_ERROR)
 
+cmake_policy(SET CMP0074 NEW)
 # project name
 if (WIN32)
     project(PCMSolver LANGUAGES CXX C) # Fortran)
diff --git a/cmake/custom/eigen.cmake b/cmake/custom/eigen.cmake
index bd635df0..f3e8d1e0 100644
--- a/cmake/custom/eigen.cmake
+++ b/cmake/custom/eigen.cmake
@@ -10,16 +10,5 @@
 #   docopt: "--eigen=<EIGEN3_ROOT> Root directory for Eigen3 [default: '']."
 #   define: "'-DEIGEN3_ROOT=\"{0}\"'.format(arguments['--eigen'])"
 
-if(EIGEN3_ROOT)
-  set(EIGEN3_INCLUDE_DIR ${EIGEN3_ROOT}/include)
-  find_package(Eigen3 3.3.0)
-  message(STATUS "Eigen " ${EIGEN3_VERSION} " is located here: " ${EIGEN3_INCLUDE_DIR})
-  if(NOT EIGEN3_FOUND)
-    set(EIGEN3_INCLUDE_DIR ${PROJECT_SOURCE_DIR}/external/eigen3/include/eigen3)
-    message(STATUS "Eigen 3.3.2 is located here: " ${EIGEN3_INCLUDE_DIR})
-  endif()
-else()
-  set(EIGEN3_INCLUDE_DIR ${PROJECT_SOURCE_DIR}/external/eigen3/include/eigen3)
-  message(STATUS "Eigen 3.3.2 is located here: " ${EIGEN3_INCLUDE_DIR})
-endif()
+find_package(Eigen3)
 include_directories(SYSTEM ${EIGEN3_INCLUDE_DIR})
-- 
